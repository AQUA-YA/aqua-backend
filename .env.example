# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/aquaya

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=*

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Swagger (production basic auth)
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin123

# Business defaults
DEFAULT_SEARCH_RADIUS_KM=5
ORDER_ACCEPT_TIMEOUT_MIN=30

# External services (not required in v1 — mocked)
# STRIPE_SECRET_KEY=
# FCM_SERVER_KEY=
# STORAGE_BUCKET=
# MAIL_API_KEY=
